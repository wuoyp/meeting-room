# Cách 1 (khuyên dùng): dán nguyên connection string Postgres
# Neon / Vercel Postgres sẽ tự cấp sẵn giá trị này cho bạn.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Cách 2: nếu không dùng DATABASE_URL, có thể khai báo rời từng biến
# (chỉ dùng khi DATABASE_URL ở trên để trống)
PGHOST=localhost
PGPORT=5432
PGDATABASE=meeting_room_db
PGUSER=postgres
PGPASSWORD=postgres
PGSSL=false

PORT=3000

# Khoá bí mật để ký JWT - PHẢI đổi giá trị này khi triển khai thực tế
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h
